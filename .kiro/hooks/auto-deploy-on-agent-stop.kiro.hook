{
  "enabled": true,
  "name": "Auto Deploy on Agent Stop",
  "description": "Notifica cuando Kiro termina cambios y pregunta si se debe ejecutar el deploy",
  "version": "1.0.0",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Kiro ha terminado de realizar cambios. Notifica al usuario que los cambios están listos y pregúntale si desea ejecutar el deploy ahora. Si responde que sí, ejecuta el script de deploy del proyecto (deploy.py o el comando correspondiente)."
  },
  "workspaceFolderName": "Proyecto 1",
  "shortName": "auto-deploy-on-agent-stop"
}
