{
  "enabled": true,
  "name": "Auto Deploy on Agent Stop",
  "description": "Notifies when Kiro finishes changes and asks if deploy should run",
  "version": "1",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "askAgent",
    "prompt": "El agente acaba de terminar sus cambios. Primero ejecuta: 'git log master --oneline -1 --format=\"%cr %s\"' para ver cuándo fue el último deploy a master. Si el resultado muestra que el último commit en master fue hace menos de 3 minutos Y contiene la palabra 'Deploy', significa que acabas de hacer un deploy — en ese caso NO hagas nada, simplemente responde 'Deploy reciente detectado, no se requiere acción.' y termina. Si no hay deploy reciente, entonces ejecuta 'python deploy.py --status', muestra el resultado de forma resumida (rama, cambios pendientes, últimos commits) y pregunta al usuario si desea hacer deploy."
  },
  "workspaceFolderName": "Proyecto 1",
  "shortName": "auto-deploy-on-agent-stop"
}